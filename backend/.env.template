# ============================================================
# NEXUSERP BACKEND — Variáveis de Ambiente
# Copie para .env e preencha os valores reais
# NUNCA commite o .env com valores reais
# ============================================================

# ── Servidor ─────────────────────────────────────────────────
NODE_ENV=production
PORT=3000

# ── Banco de dados (obrigatório) ──────────────────────────────
DATABASE_URL=postgresql://postgres:SENHA@crm-loja-postgres:5432/crm-loja

# ── JWT (obrigatório — mínimo 32 caracteres) ─────────────────
JWT_SECRET=gere_com__openssl_rand_hex_32
# JWT separado para o superadmin — deve ser diferente do JWT_SECRET
ADMIN_JWT_SECRET=gere_com__openssl_rand_hex_32_diferente
JWT_EXPIRES_IN=7d

# ── Seed do superadmin (usado apenas uma vez na instalação) ───
# Envie no header: x-seed-secret: <valor>
SEED_SECRET=gere_com__openssl_rand_hex_16

# ── Redis ─────────────────────────────────────────────────────
REDIS_PASSWORD=gere_com__openssl_rand_hex_16

# ── MinIO (storage de arquivos) ───────────────────────────────
MINIO_ENDPOINT=crm-loja-minio.ini6ln.easypanel.host
MINIO_PORT=443
MINIO_USE_SSL=true
MINIO_ACCESS_KEY=admin
MINIO_SECRET_KEY=SUA_SENHA_MINIO
MINIO_BUCKET=nexus-uploads

# ── CORS ─────────────────────────────────────────────────────
CORS_ORIGIN=https://gsntech.com.br,https://www.gsntech.com.br

# ── Rate Limiting ─────────────────────────────────────────────
RATE_LIMIT_WINDOW=900000
RATE_LIMIT_MAX=100

# ── Upload ────────────────────────────────────────────────────
MAX_FILE_SIZE=10485760

# ── Asaas — Gateway de Pagamento ─────────────────────────────
# Sandbox:   https://sandbox.asaas.com
# Produção:  https://api.asaas.com
ASAAS_API_URL=https://sandbox.asaas.com
ASAAS_API_KEY=$aact_SUA_CHAVE_AQUI
# Token enviado pelo Asaas no header asaas-access-token (obrigatório em produção)
ASAAS_WEBHOOK_TOKEN=token_secreto_configurado_no_painel_asaas
