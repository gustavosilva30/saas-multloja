# ============================================================
# NEXUS BACKEND - Environment Variables Template
# PostgreSQL + MinIO + Node.js API
# ============================================================

# ============================================================
# NODE.JS SERVER
# ============================================================
NODE_ENV=production
PORT=3000

# ============================================================
# DATABASE - PostgreSQL
# ============================================================
# Local/Docker
DATABASE_URL=postgresql://nexus:nexus_password_2024@localhost:5432/nexus_erp

# Produção (substitua com dados reais)
# DATABASE_URL=postgresql://user:password@your-vps-ip:5432/nexus_erp

# ============================================================
# JWT AUTHENTICATION
# ============================================================
# Gere uma chave segura (mínimo 32 caracteres):
# node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=sua_chave_secreta_aqui_minimo_32_caracteres_1234567890abcdef
JWT_EXPIRES_IN=7d

# ============================================================
# MINIO - S3 Compatible Storage
# ============================================================
# Local/Docker
MINIO_ENDPOINT=localhost
MINIO_PORT=9000
MINIO_USE_SSL=false
MINIO_ACCESS_KEY=nexus
MINIO_SECRET_KEY=minio_password_2024
MINIO_BUCKET=nexus-uploads

# Produção (com SSL)
# MINIO_ENDPOINT=storage.seudominio.com
# MINIO_PORT=443
# MINIO_USE_SSL=true
# MINIO_ACCESS_KEY=seu_access_key
# MINIO_SECRET_KEY=seu_secret_key

# ============================================================
# CORS - Frontend URL
# ============================================================
# Desenvolvimento
CORS_ORIGIN=http://localhost:5173

# Produção (Vercel)
# CORS_ORIGIN=https://seu-app.vercel.app

# Permissivo (não recomendado em produção)
# CORS_ORIGIN=*

# ============================================================
# RATE LIMITING
# ============================================================
RATE_LIMIT_WINDOW=900000
RATE_LIMIT_MAX=100

# ============================================================
# UPLOADS
# ============================================================
MAX_FILE_SIZE=10485760
UPLOAD_PATH=./uploads

# ============================================================
# GOOGLE GEMINI (AI Features)
# ============================================================
GEMINI_API_KEY=sua_chave_gemini_aqui

# ============================================================
# REDIS (Opcional - Cache/Sessions)
# ============================================================
# REDIS_URL=redis://localhost:6379

# ============================================================
# EMAIL/SMTP (Opcional - Notificações)
# ============================================================
# SMTP_HOST=smtp.gmail.com
# SMTP_PORT=587
# SMTP_USER=seu-email@gmail.com
# SMTP_PASS=sua-senha-app
# FROM_EMAIL=nexus@seudominio.com

# ============================================================
# LOGGING
# ============================================================
LOG_LEVEL=info
# Opções: debug, info, warn, error

# ============================================================
# FEATURE FLAGS (Desativar funcionalidades)
# ============================================================
ENABLE_REGISTRATION=true
ENABLE_SOCIAL_LOGIN=false
ENABLE_AI_ASSISTANT=true
